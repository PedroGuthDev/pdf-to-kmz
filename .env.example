# Vercel Blob — create a Blob store in the Vercel project dashboard.
# Vercel injects BLOB_READ_WRITE_TOKEN automatically on deploy.
BLOB_READ_WRITE_TOKEN=

# Optional: require Bearer token or x-api-key for POST/DELETE and client uploads
# (/api/dxf/regions, /api/dxf/upload)
DXF_API_SECRET=

# Large DXF (>3.5 MB) upload directly from the browser to Blob via /api/dxf/upload
# (max 100 MB per file, CLIENT_DXF_MAX_BYTES in lib/dxf-cloud-paths.js)
