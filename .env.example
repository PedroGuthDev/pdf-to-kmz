# Vercel Blob — create a Blob store in the Vercel project dashboard.
# Vercel injects BLOB_READ_WRITE_TOKEN automatically on deploy.
BLOB_READ_WRITE_TOKEN=

# Required for private DXF library: all list/read/upload/delete need this secret.
# Use a long random string; paste the same value in the app's "Chave API" field.
DXF_API_SECRET=

# Large DXF (>3.5 MB) upload directly from the browser to private Blob via /api/dxf/upload
